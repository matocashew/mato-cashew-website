---
import PageLayout from "../layouts/PageLayout.astro";
---

<PageLayout
  title="404 | Page Not Found | Mato Cashew"
  description="The page you are looking for could not be found. Explore Mato Cashew's premium Cambodian cashew products or return to the homepage."
  canonical="https://matocashew.com/404"
>

<section class="error-page">

  <div class="container">

    <img
      src="/images/logo/logo.png"
      alt="Mato Cashew Logo"
      class="error-logo"
      width="220"
      height="220"
      loading="eager"
      decoding="async"
    />

    <h1>404</h1>

    <h2>Page Not Found</h2>

    <p>
      Sorry, the page you are looking for doesn't exist,
      may have been moved, or the URL may be incorrect.
    </p>

    <div class="error-actions">

      <a
        href="/"
        class="btn btn-primary"
      >
        Back to Home
      </a>

      <a
        href="/products"
        class="btn btn-outline"
      >
        Browse Products
      </a>

    </div>

  </div>

</section>

</PageLayout>