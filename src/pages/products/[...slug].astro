---
import { render } from "astro:content";

import "../../styles/page.css";
import "../../styles/product-detail.css";
import "../../styles/related-products.css";

import PageLayout from "../../layouts/PageLayout.astro";
import PageHero from "../../components/PageHero.astro";

import ProductDetails from "../../components/products/ProductDetails.astro";
import ProductSpecificationsList from "../../components/products/ProductSpecificationsList.astro";
import ProductApplications from "../../components/products/ProductApplications.astro";
import RelatedProducts from "../../components/products/RelatedProducts.astro";

import ProductPageSchema from "../../components/seo/ProductPageSchema.astro";

import {
  getProducts,
  getRelatedProducts,
} from "../../services/productService";

export async function getStaticPaths() {

  const products = await getProducts();

  return products.map((product) => ({

    params: {
      slug: product.data.slug,
    },

    props: {
      product,
    },

  }));

}

const { product } = Astro.props;

const { Content } = await render(product);

const canonical =
  `https://matocashew.com/products/${product.data.slug}`;

const relatedProducts =
  await getRelatedProducts(
    product.data.slug,
    3
  );
---

<ProductPageSchema
  product={product}
  canonical={canonical}
  lang="en"
/>

<PageLayout
  title={`${product.data.title} | Mato Cashew`}
  description={product.data.description}
  canonical={canonical}
  ogType="product"
  ogImage={
    product.data.image.startsWith("http")
      ? product.data.image
      : `https://matocashew.com${product.data.image}`
  }
  breadcrumbs={[
    {
      name: "Home",
      url: "https://matocashew.com"
    },
    {
      name: "Products",
      url: "https://matocashew.com/products"
    },
    {
      name: product.data.title,
      url: canonical
    }
  ]}
>

  <PageHero
    title={product.data.title}
    description={product.data.description}
  />

  <ProductDetails
    product={product}
  />

  <ProductSpecificationsList
    specifications={product.data.specifications}
  />

  <ProductApplications
    applications={product.data.applications}
  />

  <section class="container">

    <article class="product-content">

      <Content />

    </article>

  </section>

  <RelatedProducts
    products={relatedProducts}
  />

</PageLayout>