---
import { getCollection } from "astro:content";

import "../../styles/page.css";
import "../../styles/resources.css";

import PageLayout from "../../layouts/PageLayout.astro";
import PageHero from "../../components/PageHero.astro";
import SectionTitle from "../../components/SectionTitle.astro";
import ResourceCard from "../../components/resources/ResourceCard.astro";

const articles = (await getCollection(
  "resources",
  ({ data }) => !data.draft
)).sort(
  (a, b) =>
    b.data.publishDate.getTime() -
    a.data.publishDate.getTime()
);
console.log("Articles:", articles);
---

<PageLayout
  title="Resources | Mato Cashew"
  description="Expert guides, buying advice, export insights, and educational resources about Cambodian cashews."
  canonical="https://matocashew.com/resources"
  breadcrumbs={[
    {
      name: "Home",
      url: "https://matocashew.com"
    },
    {
      name: "Resources",
      url: "https://matocashew.com/resources"
    }
  ]}
>

<PageHero
  title="Resources"
  description="Expert guides, buying advice, export insights, and educational resources from Mato Cashew."
/>

<section class="resources">

  <div class="container">

    <SectionTitle
      tag="Resources"
      title="Latest Articles"
    />

    <div class="resources-grid">

      {
        articles.map((article) => (

          <ResourceCard
            title={article.data.title}
            description={article.data.description}
            href={`/resources/${article.id}`}
            image={article.data.image}
            category={article.data.category}
            publishDate={article.data.publishDate.toLocaleDateString(
              "en-US",
              {
                year: "numeric",
                month: "long",
                day: "numeric"
              }
            )}
            readingTime={`${article.data.readingTime ?? 5} min read`}
          />

        ))
      }

    </div>

  </div>

</section>

</PageLayout>