---
import { getCollection } from "astro:content";

import "../../styles/page.css";
import "../../styles/resources.css";

import PageLayout from "../../layouts/PageLayout.astro";
import PageHero from "../../components/PageHero.astro";
import SectionTitle from "../../components/SectionTitle.astro";
import ResourceCard from "../../components/resources/ResourceCard.astro";
import ResourceGrid from "../../components/resources/ResourceGrid.astro";

const articles = (await getCollection(
  "resources",
  ({ data }) => !data.draft
)).sort(
  (a, b) =>
    b.data.publishDate.getTime() -
    a.data.publishDate.getTime()
);
console.log("Articles:", articles);
---

<PageLayout
  title="Resources | Mato Cashew"
  description="Expert guides, buying advice, export insights, and educational resources about Cambodian cashews."
  canonical="https://matocashew.com/resources"
  breadcrumbs={[
    {
      name: "Home",
      url: "https://matocashew.com"
    },
    {
      name: "Resources",
      url: "https://matocashew.com/resources"
    }
  ]}
>

<PageHero
  title="Resources"
  description="Expert guides, buying advice, export insights, and educational resources from Mato Cashew."
/>

<section class="resources">

  <div class="container">

    <SectionTitle
      tag="Resources"
      title="Latest Articles"
    />

    <ResourceGrid
      articles={articles}
    />

  </div>

</section>

</PageLayout>