---
import "../styles/page.css";
import "../styles/contact.css";
import "../styles/contact-form.css";
import PageLayout from "../layouts/PageLayout.astro";
import PageHero from "../components/PageHero.astro";
import ContactInfo from "../components/contact/ContactInfo.astro";
import ContactForm from "../components/contact/ContactForm.astro";
---

<PageLayout
  title="Contact | Mato Cashew"
  description="Contact Mato Cashew for wholesale inquiries, partnerships, and premium Cambodian cashew products."
  canonical="https://matocashew.com/contact"
  breadcrumbs={[
    {
      name: "Home",
      url: "https://matocashew.com"
    },
    {
      name: "Contact",
      url: "https://matocashew.com/contact"
    }
  ]}
>

  <PageHero
    title="Contact Us"
    description="We'd love to hear from you. Get in touch with our team today."
  />

  <section class="contact-page">

    <div class="container contact-grid">

      <ContactInfo />

      <ContactForm />

    </div>

  </section>

</PageLayout>