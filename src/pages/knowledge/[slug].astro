---
import Layout from "@layouts/Layout.astro";

import knowledgeService from "@services/knowledgeService";
import { render } from "astro:content";

export async function getStaticPaths() {
  const entries = await Promise.all(
    (await knowledgeService.getAll()).map(async (article) => {
      const entry = await knowledgeService.getEntryBySlug(article.slug);

      return {
        params: {
          slug: article.slug,
        },

        props: {
          entry,
        },
      };
    })
  );

  return entries.filter(item => item.props.entry);
}

const { entry } = Astro.props;

if (!entry) {
  throw new Error("Knowledge entry not found.");
}

const { Content } = await render(entry);

---

<Layout
  title={entry.data.title}
  description={entry.data.description}
>

<main class="container">

  <header class="knowledge-header">

  <p class="knowledge-category">
    {entry.data.category}
  </p>

  <h1>{entry.data.title}</h1>

  <p class="knowledge-description">
    {entry.data.description}
  </p>

  <div class="knowledge-meta">

    <span>
      👤 {entry.data.author}
    </span>

    <span>
      📅 {entry.data.publishedAt.toLocaleDateString()}
    </span>

    <span>
      ⏱ {entry.data.readingTime} min read
    </span>

  </div>

</header>

<hr />

<article class="knowledge-content">
  <Content />
</article>

</main>

</Layout>