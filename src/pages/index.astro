---
import Layout from "../layouts/Layout.astro";

import Header from "../components/Header.astro";
import Hero from "../components/Hero.astro";
import About from "../components/About.astro";
import Products from "../components/Products.astro";
import Gallery from "../components/Gallery.astro";
import Wholesale from "../components/Wholesale.astro";
import Contact from "../components/Contact.astro";
import Footer from "../components/Footer.astro";
---

<Layout
  title="Mato Cashew | Premium Cambodian Cashew Kernels for Local & Global Markets"
  description="Mato Cashew supplies premium Cambodian cashew kernels for retail, wholesale, export, OEM, and private label partners worldwide."
  canonical="https://matocashew.com/"
  breadcrumbs={[
    {
      name: "Home",
      url: "https://matocashew.com/"
    }
  ]}
>

  <Header />

  <main>

    <Hero />

    <About />

    <Products />

    <Gallery />

    <Wholesale />

    <Contact />

  </main>

  <Footer />

</Layout>