---
import { getCurrentLanguage } from "../i18n/getCurrentLanguage";
import { SITE } from "../config/site";

const t = getCurrentLanguage(Astro.url.pathname);

const isKhmer = Astro.url.pathname.startsWith("/km");

const homeUrl = isKhmer ? "/km" : "/";
const aboutUrl = isKhmer ? "/km/about" : "/about";
const productsUrl = isKhmer ? "/km/products" : "/products";
const resourcesUrl = isKhmer ? "/km/resources" : "/resources";
const galleryUrl = isKhmer ? "/km/gallery" : "/gallery";
const wholesaleUrl = isKhmer ? "/km/wholesale" : "/wholesale";
const contactUrl = isKhmer ? "/km/contact" : "/contact";
---

<footer class="footer">

  <div class="container footer-grid">

    <!-- Brand -->

    <div class="footer-brand">

      <a
        href={homeUrl}
        aria-label={`${SITE.brand.english} Home`}
      >

        <img
          src="/images/logo/logo-white.png"
          alt={`${SITE.brand.english} Logo`}
          width="180"
          height="60"
          loading="lazy"
          decoding="async"
        />

      </a>

      <p>
        {t.footer.description}
      </p>

    </div>

    <!-- Quick Links -->

    <div class="footer-links">

      <h4>{t.footer.quickLinks}</h4>

      <ul>

        <li><a href={aboutUrl}>{t.nav.about}</a></li>

        <li><a href={productsUrl}>{t.nav.products}</a></li>

        <li><a href={resourcesUrl}>{t.nav.resources}</a></li>

        <li><a href={galleryUrl}>{t.nav.gallery}</a></li>

        <li><a href={wholesaleUrl}>{t.nav.wholesale}</a></li>

        <li><a href={contactUrl}>{t.nav.contact}</a></li>

      </ul>

    </div>

    <!-- Contact -->

    <div class="footer-contact">

      <h4>{t.footer.contact}</h4>

      <p>

        <strong>{t.footer.email}:</strong><br />

        <a href={`mailto:${SITE.contact.email}`}>

          {SITE.contact.email}

        </a>

      </p>

      <p>

        <strong>{t.footer.phone}:</strong><br />

        <a href={`tel:${SITE.contact.phone.replace(/\s+/g, "")}`}>

          {SITE.contact.phone}

        </a>

      </p>

      <p>

        <strong>{isKhmer ? "អាសយដ្ឋាន" : "Address"}:</strong><br />

        {isKhmer
          ? SITE.address.khmer
          : SITE.address.full}

      </p>

    </div>

  </div>

  <div class="footer-bottom">

    <p>

      {SITE.copyright}

    </p>

  </div>

</footer>