---
interface Props {
  title: string;
  description: string;
  canonical: string;
  lang?: "en" | "km";
}

const {
  title,
  description,
  canonical,
  lang = "en"
} = Astro.props;

const webpage = {
  "@context": "https://schema.org",
  "@type": "WebPage",

  name: title,

  description,

  url: canonical,

  isPartOf: {
    "@type": "WebSite",
    name: "Mato Cashew",
    url: "https://matocashew.com"
  },

  inLanguage: lang
};
---

<script
  type="application/ld+json"
  set:html={JSON.stringify(webpage)}
/>