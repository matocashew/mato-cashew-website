---
const organization = {
  "@context": "https://schema.org",
  "@type": "Organization",

  name: "Mato Cashew",

  url: "https://matocashew.com",

  logo: "https://matocashew.com/images/logo/logo.png",

  image: "https://matocashew.com/images/logo/logo.png",

  description:
    "Premium Cambodian cashew kernels for local and international markets.",

  email: "info@matocashew.com",

  address: {
    "@type": "PostalAddress",

    streetAddress: "Chanloang Village, Damril Commune",

    addressLocality: "Ou Reang Ov District",

    addressRegion: "Tboung Khmum Province",

    addressCountry: "KH"
  },

  contactPoint: {
    "@type": "ContactPoint",

    contactType: "Sales",

    email: "info@matocashew.com",

    availableLanguage: [
      "English"
    ]
  }
};
---

<script
  type="application/ld+json"
  set:html={JSON.stringify(organization)}
/>