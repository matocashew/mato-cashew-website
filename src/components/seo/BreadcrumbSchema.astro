---
interface Item {
  name: string;
  url: string;
}

interface Props {
  items: Item[];
}

const { items } = Astro.props;

const breadcrumb = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",

  itemListElement: items.map((item, index) => ({
    "@type": "ListItem",

    position: index + 1,

    name: item.name,

    item: item.url
  }))
};
---

<script
    type="application/ld+json"
    set:html={JSON.stringify(breadcrumb)}
/>