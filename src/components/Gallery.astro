---
import SectionTitle from "./SectionTitle.astro";
---

<section id="gallery" class="gallery">

  <div class="container">

    <SectionTitle
      tag="Gallery"
      title="From Farm to Export"
    />

    <div class="gallery-grid">

      <div class="gallery-item large">
        <img
          src="/images/gallery/orchard.jpg"
          alt="Cambodian cashew orchard"
          width="600"
          height="400"
          loading="lazy"
          decoding="async"
        />
      </div>

      <div class="gallery-item">
        <img
          src="/images/gallery/farmers.jpg"
          alt="Cambodian cashew farmers harvesting cashew"
          width="600"
          height="400"
          loading="lazy"
          decoding="async"
        />
      </div>

      <div class="gallery-item">
        <img
          src="/images/gallery/factory.jpg"
          alt="Mato Cashew processing facility"
          width="600"
          height="400"
          loading="lazy"
          decoding="async"
        />
      </div>

      <div class="gallery-item">
        <img
          src="/images/gallery/kernels.jpg"
          alt="Premium Cambodian cashew kernels"
          width="600"
          height="400"
          loading="lazy"
          decoding="async"
        />
      </div>

      <div class="gallery-item">
        <img
          src="/images/gallery/packaging.jpg"
          alt="Export-ready cashew packaging"
          width="600"
          height="400"
          loading="lazy"
          decoding="async"
        />
      </div>

      <div class="gallery-item large">
        <img
          src="/images/gallery/export.jpg"
          alt="Cambodian cashew export shipment"
          width="600"
          height="400"
          loading="lazy"
          decoding="async"
        />
      </div>

    </div>

  </div>

</section>