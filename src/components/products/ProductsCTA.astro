---
import { getCurrentLanguage } from "../../i18n/getCurrentLanguage";

const t = getCurrentLanguage(Astro.url.pathname);
---

<section class="products-cta">

  <div class="container">

    <div class="products-cta-box">

      <span class="cta-tag">
        {t.products.cta.tag}
      </span>

      <h2>
        {t.products.cta.title}
      </h2>

      <p>
        {t.products.cta.description}
      </p>

      <div class="cta-features">

        {
          t.products.cta.features.map((feature) => (
            <span>✓ {feature}</span>
          ))
        }

      </div>

      <div class="cta-buttons">

        <a
          href="/contact"
          class="btn btn-primary"
        >
          {t.products.cta.primaryButton}
        </a>

        <a
          href="/wholesale"
          class="btn btn-outline"
        >
          {t.products.cta.secondaryButton}
        </a>

      </div>

    </div>

  </div>

</section>