---
import SectionTitle from "../SectionTitle.astro";
import { getCurrentLanguage } from "../../i18n/getCurrentLanguage";

const t = getCurrentLanguage(Astro.url.pathname);
---

<section class="packaging-options">

  <div class="container">

    <SectionTitle
      tag={t.products.packaging.tag}
      title={t.products.packaging.title}
    />

    <div class="packaging-grid">

      <article class="package-card">

        <div class="package-icon">🛍️</div>

        <h3>
          {t.products.packaging.items.retail.title}
        </h3>

        <p>
          {t.products.packaging.items.retail.description}
        </p>

      </article>

      <article class="package-card">

        <div class="package-icon">📦</div>

        <h3>
          {t.products.packaging.items.bulk.title}
        </h3>

        <p>
          {t.products.packaging.items.bulk.description}
        </p>

      </article>

      <article class="package-card">

        <div class="package-icon">🏷️</div>

        <h3>
          {t.products.packaging.items.privateLabel.title}
        </h3>

        <p>
          {t.products.packaging.items.privateLabel.description}
        </p>

      </article>

    </div>

  </div>

</section>