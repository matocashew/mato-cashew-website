---
import SectionTitle from "../SectionTitle.astro";
---

<section class="packaging-options">

    <div class="container">

        <SectionTitle
            tag="Packaging"
            title="Packaging Options"
        />

        <div class="packaging-grid">

            <article class="package-card">

                <div class="package-icon">🛍️</div>

                <h3>Retail Packaging</h3>

                <p>
                    Available in 100g, 250g and 500g premium stand-up pouches
                    for supermarkets and retail stores.
                </p>

            </article>

            <article class="package-card">

                <div class="package-icon">📦</div>

                <h3>Bulk Packaging</h3>

                <p>
                    Food-grade vacuum bags packed in export cartons,
                    suitable for distributors and manufacturers.
                </p>

            </article>

            <article class="package-card">

                <div class="package-icon">🏷️</div>

                <h3>Private Label</h3>

                <p>
                    OEM and private label services with custom packaging
                    and branding for international partners.
                </p>

            </article>

        </div>

    </div>

</section>