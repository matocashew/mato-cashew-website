---
import SectionTitle from "../SectionTitle.astro";
import { getCurrentLanguage } from "../../i18n/getCurrentLanguage";

const t = getCurrentLanguage(Astro.url.pathname);
---

<section class="product-specifications">

  <div class="container">

    <SectionTitle
      tag={t.products.specifications.tag}
      title={t.products.specifications.title}
    />

    <div class="spec-table-wrapper">

      <table class="spec-table responsive-table">

        <tbody>

          <tr>
            <th>{t.products.specifications.rows.product}</th>
            <td>{t.products.specifications.rows.productValue}</td>
          </tr>

          <tr>
            <th>{t.products.specifications.rows.origin}</th>
            <td>{t.products.specifications.rows.originValue}</td>
          </tr>

          <tr>
            <th>{t.products.specifications.rows.grades}</th>
            <td>{t.products.specifications.rows.gradesValue}</td>
          </tr>

          <tr>
            <th>{t.products.specifications.rows.moisture}</th>
            <td>{t.products.specifications.rows.moistureValue}</td>
          </tr>

          <tr>
            <th>{t.products.specifications.rows.broken}</th>
            <td>{t.products.specifications.rows.brokenValue}</td>
          </tr>

          <tr>
            <th>{t.products.specifications.rows.shelfLife}</th>
            <td>{t.products.specifications.rows.shelfLifeValue}</td>
          </tr>

          <tr>
            <th>{t.products.specifications.rows.storage}</th>
            <td>{t.products.specifications.rows.storageValue}</td>
          </tr>

          <tr>
            <th>{t.products.specifications.rows.packaging}</th>
            <td>{t.products.specifications.rows.packagingValue}</td>
          </tr>

          <tr>
            <th>{t.products.specifications.rows.certification}</th>
            <td>{t.products.specifications.rows.certificationValue}</td>
          </tr>

        </tbody>

      </table>

    </div>

  </div>

</section>