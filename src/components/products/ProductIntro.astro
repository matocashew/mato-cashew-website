---
import SectionTitle from "../SectionTitle.astro";
---

<section class="product-intro">

    <div class="container intro-grid">

        <div class="intro-content">

            <SectionTitle
                tag="Our Products"
                title="Premium Cambodian Cashew Kernels"
            />

            <p>
                Mato Cashew offers carefully selected premium Cambodian
                cashew kernels for both retail and wholesale markets.
                Every kernel is processed under strict quality control
                to ensure freshness, natural taste, and export quality.
            </p>

            <ul class="intro-list">

                <li>✔ Whole White Kernels</li>
                <li>✔ Vacuum Packed</li>
                <li>✔ Export Quality</li>
                <li>✔ OEM & Private Label Available</li>

            </ul>

        </div>

        <div class="intro-image">

            <img
                src="/images/products/premium-kernels.png"
                alt="Premium Cambodian Cashew Kernels"
            />

        </div>

    </div>

</section>