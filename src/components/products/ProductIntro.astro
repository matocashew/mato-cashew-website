---
import { getCurrentLanguage } from "../../i18n/getCurrentLanguage";

const t = getCurrentLanguage(Astro.url.pathname);
---

<section class="product-intro">

  <div class="container">

    <span class="section-tag">
      {t.products.intro.tag}
    </span>

    <h2>
      {t.products.intro.title}
    </h2>

    <p>
      {t.products.intro.description}
    </p>

  </div>

</section>