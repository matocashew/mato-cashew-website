---
import SectionTitle from "../SectionTitle.astro";
import { getCurrentLanguage } from "../../i18n/getCurrentLanguage";

const t = getCurrentLanguage(Astro.url.pathname);
---

<section class="wholesale-products">

  <div class="container">

    <SectionTitle
      tag={t.products.wholesale.tag}
      title={t.products.wholesale.title}
    />

    <div class="wholesale-products-grid">

      <article class="bulk-card">

        <h3>{t.products.wholesale.items.vacuum10kg.title}</h3>

        <p>
          {t.products.wholesale.items.vacuum10kg.description}
        </p>

        <ul>
          {
            t.products.wholesale.items.vacuum10kg.features.map((feature) => (
              <li>✓ {feature}</li>
            ))
          }
        </ul>

        <a
          href="/contact"
          class="btn btn-primary"
        >
          {t.common.requestQuote}
        </a>

      </article>

      <article class="bulk-card">

        <h3>{t.products.wholesale.items.exportCarton.title}</h3>

        <p>
          {t.products.wholesale.items.exportCarton.description}
        </p>

        <ul>
          {
            t.products.wholesale.items.exportCarton.features.map((feature) => (
              <li>✓ {feature}</li>
            ))
          }
        </ul>

        <a
          href="/contact"
          class="btn btn-primary"
        >
          {t.common.requestQuote}
        </a>

      </article>

    </div>

  </div>

</section>