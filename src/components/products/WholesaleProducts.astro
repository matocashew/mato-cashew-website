---
import SectionTitle from "../SectionTitle.astro";
---

<section class="wholesale-products">

    <div class="container">

        <SectionTitle
            tag="Wholesale Products"
            title="Bulk Packaging for International Buyers"
        />

        <div class="wholesale-products-grid">

            <article class="bulk-card">

                <h3>10kg Vacuum Pack</h3>

                <p>
                    Premium whole white kernels packed in food-grade vacuum
                    bags for maximum freshness.
                </p>

                <ul>

                    <li>✓ Export Ready</li>
                    <li>✓ Food Grade Packaging</li>
                    <li>✓ Vacuum Sealed</li>
                    <li>✓ OEM Available</li>

                </ul>

                <a
                    href="/contact"
                    class="btn btn-primary"
                >
                    Request Quote
                </a>

            </article>

            <article class="bulk-card">

                <h3>22.68kg Export Carton (50 lbs)</h3>

                <p>
                    Designed for international distributors and food
                    manufacturers requiring large-volume supply.
                </p>

                <ul>

                    <li>✓ Bulk Export</li>
                    <li>✓ Private Label</li>
                    <li>✓ International Shipping</li>
                    <li>✓ Consistent Quality</li>

                </ul>

                <a
                    href="/contact"
                    class="btn btn-primary"
                >
                    Request Quote
                </a>

            </article>

        </div>

    </div>

</section>