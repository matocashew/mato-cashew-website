---
import SectionTitle from "./SectionTitle.astro";
import { getCurrentLanguage } from "../i18n/getCurrentLanguage";

const t = getCurrentLanguage(
  Astro.url.pathname
);
---

<section id="wholesale" class="wholesale">

    <div class="container wholesale-grid">

        <div class="wholesale-content">

            <SectionTitle
                tag={t.wholesaleHome.tag}
                title={t.wholesaleHome.title}
            />

                <p>
                    {t.wholesaleHome.description}
                </p>

            <ul class="wholesale-list">

                <li>🌍 {t.wholesaleHome.features.export}</li>

                <li>📦 {t.wholesaleHome.features.packaging}</li>

                <li>🏆 {t.wholesaleHome.features.quality}</li>

                <li>🤝 {t.wholesaleHome.features.privateLabel}</li>

            </ul>

            <a
                href="#contact"
                class="btn btn-primary"
            >
                {t.wholesaleHome.cta}
            </a>

        </div>

        <div class="wholesale-image">

            <img
                src="/images/wholesale/export.jpg"
                alt={t.wholesaleHome.imageAlt}
            />

        </div>

    </div>

</section>