---
import SectionTitle from "./SectionTitle.astro";
---

<section id="wholesale" class="wholesale">

    <div class="container wholesale-grid">

        <div class="wholesale-content">

            <SectionTitle
                tag="Wholesale"
                title="Export Premium Cambodian Cashew Worldwide"
            />

            <p>
                Mato Cashew supplies premium Cambodian cashew kernels
                to international importers, distributors, supermarkets,
                and food manufacturers. We provide reliable quality,
                competitive pricing, and export-ready packaging.
            </p>

            <ul class="wholesale-list">

                <li>🌍 Worldwide Export</li>

                <li>📦 Food Grade Packaging</li>

                <li>🏆 International Quality Standard</li>

                <li>🤝 OEM & Private Label Available</li>

            </ul>

            <a
                href="#contact"
                class="btn btn-primary"
            >
                Request Wholesale Quote
            </a>

        </div>

        <div class="wholesale-image">

            <img
                src="/images/wholesale/export.jpg"
                alt="Wholesale Export"
            />

        </div>

    </div>

</section>