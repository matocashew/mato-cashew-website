---
import { getCurrentLanguage } from "../i18n/getCurrentLanguage";

import LanguageSwitcher from "./LanguageSwitcher.astro";

const currentPath = Astro.url.pathname;

const isKhmer = currentPath.startsWith("/km");

const basePath = isKhmer ? "/km" : "";

const t = getCurrentLanguage(
  Astro.url.pathname
);

const homePath = isKhmer ? "/km/" : "/";
---
<header class="header">

  <div class="container header-wrapper">

    <a
        href={homePath}
        class="logo"
        aria-label="Mato Cashew Home"
    >

      <img src="/images/logo/logo.png" alt="Mato Cashew Logo" />

    </a>

    <nav aria-label="Main navigation">
        
    <button
        type="button"
        aria-controls="main-menu"
        class="menu-toggle"
        aria-label="Toggle Menu"
        aria-expanded="false"
    >
        ☰
    </button>

        <ul id="main-menu" class="nav-menu">

        <li>
            <a
            href={homePath}
            class={currentPath === "/" ? "active" : ""}
            >
            {t.nav.home}
            </a>
        </li>

        <li>
            <a
            href={`${basePath}/about`}
            class={
            currentPath === `${basePath}/about`
                ? "active"
                : ""
            }
            >
            {t.nav.about}
            </a>
        </li>

        <li>
            <a
            href={`${basePath}/products`}
            class={currentPath === "/products" ? "active" : ""}
            >
            {t.nav.products}
            </a>
        </li>

        <li>
            <a
                href={`${basePath}/resources`}
                class={currentPath.startsWith("/resources") ? "active" : ""}
            >
                {t.nav.resources}
            </a>
        </li>

        <li>
            <a
            href={`${basePath}/gallery`}
            class={currentPath === "/gallery" ? "active" : ""}
            >
            {t.nav.gallery}
            </a>
        </li>

        <li>
            <a
            href={`${basePath}/wholesale`}
            class={currentPath === "/wholesale" ? "active" : ""}
            >
            {t.nav.wholesale}
            </a>
        </li>

        <li>
            <a
            href={`${basePath}/contact`}
            class={currentPath === "/contact" ? "active" : ""}
            >
            {t.nav.contact}
            </a>
        </li>

        </ul>

    </nav>

    <LanguageSwitcher />

  </div>

</header>

<script>
document.addEventListener("DOMContentLoaded", () => {

    const header = document.querySelector(".header");

    if (header) {

        window.addEventListener("scroll", () => {

            if (window.scrollY > 40) {

                header.classList.add("scrolled");

            } else {

                header.classList.remove("scrolled");

            }

        });

    }

    const menuToggle = document.querySelector(".menu-toggle");
const navMenu = document.querySelector(".nav-menu");

if (menuToggle && navMenu) {

    menuToggle.addEventListener("click", () => {

        navMenu.classList.toggle("open");

        const expanded =
            menuToggle.getAttribute("aria-expanded") === "true";

        menuToggle.setAttribute(
            "aria-expanded",
            (!expanded).toString()
        );

        menuToggle.textContent = expanded ? "☰" : "✕";

    });

}
const navLinks = document.querySelectorAll(".nav-menu a");
navLinks.forEach((link) => {

    link.addEventListener("click", () => {

        if (navMenu) {

            navMenu.classList.remove("open");

        }

        if (menuToggle) {

            menuToggle.textContent = "☰";

            menuToggle.setAttribute("aria-expanded", "false");

        }

    });

});

});

</script>

<script type="module">

  import { initLanguageSwitcher }
    from "../scripts/language-switcher.ts";

  document.addEventListener(
    "DOMContentLoaded",
    initLanguageSwitcher
  );

</script>
