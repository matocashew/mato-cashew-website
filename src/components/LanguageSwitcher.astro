---
const isKhmer = Astro.url.pathname.startsWith("/km");

const currentLanguage = isKhmer
  ? {
      code: "km",
      label: "ខ្មែរ",
      flag: "/images/flags/kh.svg",
    }
  : {
      code: "en",
      label: "English",
      flag: "/images/flags/us.svg",
    };
---
<div class="language-switcher">

  <button
    type="button"
    class="language-current"
    aria-haspopup="true"
    aria-expanded="false"
  >

    <img
      src={currentLanguage.flag}
      alt=""
      width="20"
      height="15"
    />

    <span>{currentLanguage.label}</span>

    <span class="arrow">▼</span>

  </button>

  <div class="language-dropdown">

    <button
      type="button"
      class={`language-option ${
        currentLanguage.code === "en"
          ? "active"
          : ""
      }`}
      data-language="en"
    >

      <img
        src="/images/flags/us.svg"
        alt=""
        width="24"
        height="18"
      />

      <span>English</span>

      {
        currentLanguage.code === "en" && (
          <span class="check">✓</span>
        )
      }

    </button>

    <button
      type="button"
      class={`language-option ${
        currentLanguage.code === "km"
          ? "active"
          : ""
      }`}
      data-language="km"
    >

      <img
        src="/images/flags/kh.svg"
        alt=""
        width="24"
        height="18"
      />

      <span>ខ្មែរ</span>

      {
        currentLanguage.code === "km" && (
          <span class="check">✓</span>
        )
      }

    </button>

  </div>

</div>