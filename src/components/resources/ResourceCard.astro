---
interface Props {
  title: string;
  description: string;
  href: string;
  image: string;

  category: string;

  publishDate: string;

  readingTime: string;
}

const {
  title,
  description,
  href,
  image,
  category,
  publishDate,
  readingTime
} = Astro.props;
---

<article class="resource-card">

    <a href={href} class="resource-image">

        <img
            src={image}
            alt={title}
            width="640"
            height="360"
            loading="lazy"
            decoding="async"
        />

    </a>

    <div class="resource-content">

        <span class="resource-category">
            {category}
        </span>

        <h3>

            <a href={href}>
                {title}
            </a>

        </h3>

        <p>
            {description}
        </p>

        <div class="resource-meta">

            <span>{publishDate}</span>

            <span>•</span>

            <span>{readingTime}</span>

        </div>

        <a
            href={href}
            class="resource-link"
        >
            Read Article →
        </a>

    </div>

</article>