---
interface Props {
  category: string;
  author: string;
  publishDate: Date;
  readingTime?: number;
  tags?: string[];
}

const {
  category,
  author,
  publishDate,
  readingTime,
  tags = []
} = Astro.props;
---

<div class="resource-meta">

  <div class="resource-meta__info">

    <span>
      <strong>Category:</strong>
      {category}
    </span>

    <span>
      <strong>Author:</strong>
      {author}
    </span>

    <span>
      <strong>Published:</strong>
      {publishDate.toLocaleDateString("en-US")}
    </span>

    {
      readingTime && (
        <span>
          <strong>Reading Time:</strong>
          {readingTime} min
        </span>
      )
    }

  </div>

  {
    tags.length > 0 && (

      <div class="resource-meta__tags">

        {
          tags.map(tag => (

            <span class="tag">

              {tag}

            </span>

          ))
        }

      </div>

    )
  }

</div>