---
import { getCurrentLanguage } from "../i18n/getCurrentLanguage";

const t = getCurrentLanguage(
  Astro.url.pathname
);
---
<section class="hero">

  <div class="container hero-grid">

    <div class="hero-content">

      <span class="hero-tag">
        {t.hero.tag}
      </span>

        <h1>{t.hero.title}</h1>

      <p>
        {t.hero.description}
      </p>

      <div class="hero-buttons">

        <a href="/products" class="btn btn-primary">
          {t.common.viewProducts}
        </a>

        <a href="/contact" class="btn btn-outline">
          {t.common.contactUs}
        </a>

      </div>

    </div>

      <div class="hero-image">

        <picture>

          <source
            srcset="/images/products/package.webp"
            type="image/webp"
          />

          <img
            src="/images/products/package.png"
            alt="Premium Cambodian cashew kernels by Mato Cashew"
            width="600"
            height="700"
            loading="eager"
            fetchpriority="high"
            decoding="async"
          />

        </picture>

      </div>

  </div>

</section>