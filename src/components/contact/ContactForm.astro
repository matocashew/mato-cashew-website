---
import { getLanguage } from "../../i18n/getLanguage";

import FormField from "./FormField.astro";
import FormSelect from "./FormSelect.astro";
import FormTextarea from "./FormTextarea.astro";

const t = getLanguage("en");

const inquiryOptions = [
  {
    value: "Wholesale Inquiry",
    label: t.contact.options.wholesale,
  },
  {
    value: "Retail Inquiry",
    label: t.contact.options.retail,
  },
  {
    value: "Distributor Request",
    label: t.contact.options.distributor,
  },
  {
    value: "Export Partnership",
    label: t.contact.options.export,
  },
  {
    value: "OEM / Private Label",
    label: t.contact.options.oem,
  },
  {
    value: "General Inquiry",
    label: t.contact.options.general,
  },
];

const volumeOptions = [
  {
    value: "Less than 100 kg",
    label: t.contact.volumeOptions.less100,
  },
  {
    value: "100–500 kg",
    label: t.contact.volumeOptions.kg100500,
  },
  {
    value: "500 kg–1 ton",
    label: t.contact.volumeOptions.kg5001ton,
  },
  {
    value: "More than 1 ton",
    label: t.contact.volumeOptions.more1ton,
  },
];
---

<div
  id="successMessage"
  class="success-message"
  hidden
>
  ✅ Thank you! Your inquiry has been sent successfully.
</div>

<div
  id="formError"
  class="form-error"
  hidden
>
  ❌ Sorry, something went wrong. Please try again.
</div>

<form
  id="contact-form"
  class="contact-form"
  novalidate
>

  <FormField
    id="name"
    name="name"
    label={t.contact.name}
    placeholder={t.contact.placeholders.name}
    autocomplete="name"
    required
  />

  <FormField
    id="company"
    name="company"
    label={t.contact.company}
    placeholder={t.contact.placeholders.company}
    autocomplete="organization"
  />

  <FormField
    id="country"
    name="country"
    label={t.contact.country}
    placeholder={t.contact.placeholders.country}
    required
  />

  <FormField
    id="email"
    name="email"
    type="email"
    label={t.contact.email}
    placeholder={t.contact.placeholders.email}
    autocomplete="email"
    required
  />

  <FormField
    id="phone"
    name="phone"
    type="tel"
    label={t.contact.phone}
    placeholder={t.contact.placeholders.phone}
    autocomplete="tel"
  />

  <FormSelect
    id="inquiry"
    name="inquiry"
    label={t.contact.inquiry}
    placeholder={t.common.selectOption}
    required
    options={inquiryOptions}
  />

  <FormSelect
    id="volume"
    name="volume"
    label={t.contact.volume}
    placeholder={t.common.selectVolume}
    options={volumeOptions}
  />

  <FormTextarea
    id="message"
    name="message"
    label={t.contact.message}
    placeholder={t.contact.placeholders.message}
    rows={6}
    required
  />

  <div
    class="cf-turnstile"
    data-sitekey="0x4AAAAAADzApl_-GPhwXu0j"
  ></div>

  <button
    id="submitBtn"
    type="submit"
    class="btn btn-primary"
  >
    <span class="btn-text">
      {t.contact.send}
    </span>
  </button>

  <p class="privacy-note">
    {t.contact.privacy}
  </p>

</form>

<script>
  import "../../scripts/contact";
</script>