---
import { getLanguage } from "../../i18n/getLanguage";
import SectionTitle from "../SectionTitle.astro";

const t = getLanguage("en");
---

<section class="quality-standards">

  <div class="container quality-grid">

    <div class="quality-content">

      <SectionTitle
        tag={t.about.qualityStandards.tag}
        title={t.about.qualityStandards.title}
      />

      <p>
        {t.about.qualityStandards.description}
      </p>

      <ul class="quality-list">

        {
          t.about.qualityStandards.items.map((item) => (
            <li>✅ {item}</li>
          ))
        }

      </ul>

    </div>

    <div class="quality-image">

      <img
        src="/images/about/quality.jpg"
        alt="Quality Standards"
        loading="lazy"
        decoding="async"
      />

    </div>

  </div>

</section>