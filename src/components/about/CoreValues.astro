---
import SectionTitle from "../SectionTitle.astro";
---
<section class="core-values">

  <div class="container">

    <SectionTitle
      tag="Our Values"
      title="What We Stand For"
    />

    <div class="values-grid">

      <article class="value-card">

        <div class="value-icon">🌱</div>

        <h3>Sustainability</h3>

        <p>
          Supporting environmentally responsible farming
          and long-term agricultural development.
        </p>

      </article>

      <article class="value-card">

        <div class="value-icon">🤝</div>

        <h3>Integrity</h3>

        <p>
          Building trust through transparency,
          honesty, and reliable partnerships.
        </p>

      </article>

      <article class="value-card">

        <div class="value-icon">🏆</div>

        <h3>Quality</h3>

        <p>
          Delivering premium Cambodian cashew kernels
          that consistently meet export standards.
        </p>

      </article>

    </div>

  </div>

</section>