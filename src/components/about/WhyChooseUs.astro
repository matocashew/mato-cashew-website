---
import SectionTitle from "../SectionTitle.astro";
import { getCurrentLanguage } from "../../i18n/getCurrentLanguage";

const t = getCurrentLanguage(
  Astro.url.pathname
);
---

<section class="why-choose">

  <div class="container">

    <SectionTitle
      tag={t.about.whyChooseUs.tag}
      title={t.about.whyChooseUs.title}
    />

    <div class="choose-grid">

      <article class="choose-card">

        <div class="choose-icon">🌱</div>

        <h3>
          {t.about.whyChooseUs.premiumOrigin.title}
        </h3>

        <p>
          {t.about.whyChooseUs.premiumOrigin.description}
        </p>

      </article>

      <article class="choose-card">

        <div class="choose-icon">🏭</div>

        <h3>
          {t.about.whyChooseUs.modernProcessing.title}
        </h3>

        <p>
          {t.about.whyChooseUs.modernProcessing.description}
        </p>

      </article>

      <article class="choose-card">

        <div class="choose-icon">🌍</div>

        <h3>
          {t.about.whyChooseUs.exportReady.title}
        </h3>

        <p>
          {t.about.whyChooseUs.exportReady.description}
        </p>

      </article>

      <article class="choose-card">

        <div class="choose-icon">🤝</div>

        <h3>
          {t.about.whyChooseUs.partnership.title}
        </h3>

        <p>
          {t.about.whyChooseUs.partnership.description}
        </p>

      </article>

    </div>

  </div>

</section>