---
import SectionTitle from "../SectionTitle.astro";
---

<section class="our-process">

  <div class="container">

    <SectionTitle
      tag="Our Process"
      title="From Farm to Global Markets"
    />

    <div class="process-grid">

      <article class="process-card">
        <div class="process-number">01</div>
        <h3>Cashew Orchard</h3>
        <p>
          Premium cashew apples are harvested from carefully managed
          orchards across Cambodia.
        </p>
      </article>

      <article class="process-card">
        <div class="process-number">02</div>
        <h3>Processing</h3>
        <p>
          Nuts are steamed, shelled, dried, peeled, graded,
          and inspected under strict quality control.
        </p>
      </article>

      <article class="process-card">
        <div class="process-number">03</div>
        <h3>Packaging</h3>
        <p>
          Kernels are vacuum packed using export-grade food
          packaging to preserve freshness.
        </p>
      </article>

      <article class="process-card">
        <div class="process-number">04</div>
        <h3>Worldwide Export</h3>
        <p>
          Finished products are prepared for international
          buyers with reliable logistics and documentation.
        </p>
      </article>

    </div>

  </div>

</section>