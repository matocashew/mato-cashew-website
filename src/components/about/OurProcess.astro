---
import SectionTitle from "../SectionTitle.astro";
import { getCurrentLanguage } from "../../i18n/getCurrentLanguage";

const t = getCurrentLanguage(
  Astro.url.pathname
);
---

<section class="our-process">

  <div class="container">

    <SectionTitle
      tag={t.about.process.tag}
      title={t.about.process.title}
    />

    <div class="process-grid">

      <article class="process-card">

        <div class="process-number">01</div>

        <h3>
          {t.about.process.orchard.title}
        </h3>

        <p>
          {t.about.process.orchard.description}
        </p>

      </article>

      <article class="process-card">

        <div class="process-number">02</div>

        <h3>
          {t.about.process.processing.title}
        </h3>

        <p>
          {t.about.process.processing.description}
        </p>

      </article>

      <article class="process-card">

        <div class="process-number">03</div>

        <h3>
          {t.about.process.packaging.title}
        </h3>

        <p>
          {t.about.process.packaging.description}
        </p>

      </article>

      <article class="process-card">

        <div class="process-number">04</div>

        <h3>
          {t.about.process.export.title}
        </h3>

        <p>
          {t.about.process.export.description}
        </p>

      </article>

    </div>

  </div>

</section>