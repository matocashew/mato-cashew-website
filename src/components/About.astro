---
import SectionTitle from "./SectionTitle.astro";
---

<section id="about" class="about">

  <div class="container about-grid">

    <div class="about-image">

      <img
          src="/images/about/about-orchard.jpg"
          alt="Mato Cashew Orchard"
          loading="lazy"
          decoding="async"
      />

    </div>

    <div class="about-content">

      <SectionTitle
        tag="About Mato Cashew"
        title="Premium Cambodian Cashew"
      />

      <p>
        Mato Cashew works directly with Cambodian farmers to
        produce high-quality cashew nuts that meet international
        export standards. Every batch is carefully selected,
        processed, and packed to ensure freshness and excellent taste.
      </p>

      <ul class="about-list">

        <li>🌿 Premium Quality</li>
        <li>🤝 Direct from Farmers</li>
        <li>🌍 Export Standard</li>
        <li>♻️ Sustainable Agriculture</li>

      </ul>

        <a
            href="/products"
            class="btn btn-primary"
        >
            Explore Products
        </a>

    </div>

  </div>

</section>