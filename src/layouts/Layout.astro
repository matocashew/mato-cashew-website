---
import OrganizationSchema from "../components/seo/OrganizationSchema.astro";
import WebsiteSchema from "../components/seo/WebsiteSchema.astro";
import WebPageSchema from "../components/seo/WebPageSchema.astro";
import BreadcrumbSchema from "../components/seo/BreadcrumbSchema.astro";

import "../styles/global.css";
import "../styles/header.css";
import "../styles/footer.css";
import "../styles/section-title.css";
import "../styles/featured-resources.css";
import "../styles/product-specifications.css";

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  robots?: string;
  breadcrumbs?: {
    name: string;
    url: string;
  }[];
}

const siteUrl = "https://matocashew.com";

const {
  title = "Mato Cashew | Premium Cambodian Cashew",
  description = "Premium Cambodian Cashew for Local & International Markets.",
  canonical = siteUrl,
  robots = "index,follow",
  breadcrumbs = []
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en">

<head>

  <OrganizationSchema />

  <WebsiteSchema />

  <WebPageSchema
    title={title}
    description={description}
    canonical={canonical}
  />

  {
    breadcrumbs.length > 0 && (
      <BreadcrumbSchema items={breadcrumbs} />
    )
  }

  <meta charset="UTF-8" />

  <meta
    name="viewport"
    content="width=device-width, initial-scale=1"
  />

  <!-- Google Fonts -->

  <link
    rel="preconnect"
    href="https://fonts.googleapis.com"
  />

  <link
    rel="preconnect"
    href="https://fonts.gstatic.com"
    crossorigin
  />

  <link
    rel="preload"
    as="style"
    href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&family=Noto+Sans+Khmer:wght@100..900&display=swap"
  />

  <link
    rel="stylesheet"
    href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&family=Noto+Sans+Khmer:wght@100..900&display=swap"
  />

  <title>{title}</title>

  <meta
    name="description"
    content={description}
  />

  <meta
    name="robots"
    content={robots}
  />

  <meta
    name="author"
    content="Mato Cashew"
  />

  <meta
    name="keywords"
    content="Cambodian Cashew, Premium Cashew, Cashew Kernels, Wholesale Cashew, Export Cashew"
  />

  <link
    rel="canonical"
    href={canonical}
  />

  <link
    rel="icon"
    type="image/png"
    sizes="32x32"
    href="/favicon-32x32.png"
  />

  <link
    rel="icon"
    type="image/png"
    sizes="16x16"
    href="/favicon-16x16.png"
  />

  <link
    rel="shortcut icon"
    href="/favicon.ico"
  />

  <link
    rel="apple-touch-icon"
    href="/apple-touch-icon.png"
  />

  <link
    rel="manifest"
    href="/site.webmanifest"
  />

  <meta
    name="theme-color"
    content="#0D5C3A"
  />

  <!-- Open Graph -->

  <meta property="og:type" content="website" />

  <meta property="og:site_name" content="Mato Cashew" />

  <meta property="og:title" content={title} />

  <meta property="og:description" content={description} />

  <meta property="og:url" content={canonical} />

  <meta
    property="og:image"
    content={`${siteUrl}/images/seo/og-image.jpg`}
  />

  <meta property="og:image:width" content="1200" />

  <meta property="og:image:height" content="630" />

  <meta
    property="og:image:alt"
    content="Mato Cashew Premium Cambodian Cashew"
  />

  <meta property="og:locale" content="en_US" />

  <!-- Twitter -->

  <meta
    name="twitter:card"
    content="summary_large_image"
  />

  <meta
    name="twitter:title"
    content={title}
  />

  <meta
    name="twitter:description"
    content={description}
  />

  <meta
    name="twitter:image"
    content={`${siteUrl}/images/seo/og-image.jpg`}
  />

  <!-- Google Analytics -->

  <script
    async
    src="https://www.googletagmanager.com/gtag/js?id=G-9CBMMS5DPF"
  ></script>

  <script is:inline>
    window.dataLayer = window.dataLayer || [];

    function gtag() {
      dataLayer.push(arguments);
    }

    gtag("js", new Date());

    gtag("config", "G-9CBMMS5DPF");
  </script>

  <!-- Cloudflare Turnstile -->

  <script
    src="https://challenges.cloudflare.com/turnstile/v0/api.js"
    async
    defer
  ></script>

</head>

<body>

  <slot />

</body>

</html>