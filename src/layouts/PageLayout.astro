---
import Layout from "./Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

interface Props {
  title: string;
  description: string;
  canonical: string;
  breadcrumbs?: {
    name: string;
    url: string;
  }[];
}

const {
  title,
  description,
  canonical,
  breadcrumbs = []
} = Astro.props;
---

<Layout
  title={title}
  description={description}
  canonical={canonical}
  breadcrumbs={breadcrumbs}
>

  <Header />

  <main>
    <slot />
  </main>

  <Footer />

</Layout>